{
    "$schema": "https://railway.app/get-started/config/railway.schema.json",
    "build": {
        "builder": "NIXPACKS"
    },
    "deploy": {
        "startCommand": "node build-server/server.js",
        "healthcheckPath": "/v1/health",
        "healthcheckTimeout": 60,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
    },
    "env": {
        "PORT": "3000"
    }
}